node_modules/
*.log

# dist/ is otherwise committed (compiled outputs, so non-technical users can
# use the data straight from GitHub without running the build) except the
# two files that are just heavier restatements of what's already in
# dist/uganda-locations-full.csv and the smaller per-level JSON exports:
# uganda-locations.json (~39MB, the full unified tree) and villages.json
# (~33MB, the single biggest per-level export). Run `npm run build` for
# either.
dist/uganda-locations.json
dist/villages.json

# Large regenerable EC provenance artifacts: the source PDF is re-fetchable
# from the URL cited in data/sources.json (src-ec-admin-units-2022), and the
# raw parse is regenerable by re-running parse_admin_units.mjs against it.
# data/ec/administrative_units_ec2022.json (the canonical, schema-shaped
# output scripts/build.mjs actually consumes) IS tracked despite its size,
# so `npm run build` works from a fresh clone without needing either of these.
data/legacy/provenance/ec/admin-units-2022.pdf
data/legacy/provenance/ec/parsed_admin_units_2022.json

# Same reasoning for the large raw boundary/road sources: each is
# re-fetchable from the URL cited in its data/sources.json entry, and the
# curated data/geo/*.geojson output scripts/ingest-*.mjs actually produces
# IS tracked, so `npm run build` works from a fresh clone without these.
data/legacy/provenance/geo/geoBoundaries-UGA-ADM4.geojson
data/legacy/provenance/geo/hdx-uga-admin4-parish.geojson
